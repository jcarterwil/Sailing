NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
NEXT_PUBLIC_GOOGLE_AUTH_ENABLED=false
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Server-only secrets. Never expose with a NEXT_PUBLIC_ prefix.
SUPABASE_SECRET_KEY=
ANTHROPIC_API_KEY=
# Application email through Resend. Supabase Auth email is configured separately.
RESEND_API_KEY=
RESEND_WEBHOOK_SECRET=
RESEND_FROM_EMAIL="Sailing <notifications@example.com>"
# Used when inbound receiving is not configured.
RESEND_REPLY_TO=
# A Resend receiving domain, ideally an isolated subdomain such as reply.example.com.
RESEND_INBOUND_DOMAIN=
# Signs the admin "act as owner" impersonation cookie. A strong random string
# (e.g. `openssl rand -base64 32`). Required for the impersonation feature.
IMPERSONATION_COOKIE_SECRET=
